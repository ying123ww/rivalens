# =============================================================================
# Rivalens 部署配置模板
# 复制为 .env 后填入实际值即可运行:  cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# 必填：LLM API
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：Anthropic
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_AUTH_TOKEN=sk-ant-your-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# 必填：搜索检索器（至少配一个）
# ---------------------------------------------------------------------------
RETRIEVER=tavily
TAVILY_API_KEY=tvly-your-tavily-key
# 可选：UniFuncs DeepSearch（中文生态）
# UNIFUNCS_API_KEY=sk-your-unifuncs-key
# UNIFUNCS_DEEPSEARCH_BASE_URL=https://api.unifuncs.com/deepsearch/v1
# UNIFUNCS_DEEPSEARCH_MODEL=s3-pro
# UNIFUNCS_DEEPSEARCH_LANGUAGE=zh

# ---------------------------------------------------------------------------
# LLM 模型分配（provider:model 格式）
# ---------------------------------------------------------------------------
FAST_LLM=openai:gpt-4.1-mini
SMART_LLM=openai:gpt-4.1-mini
STRATEGIC_LLM=openai:gpt-4.1-mini
# 行业匹配回退 LLM
# INDUSTRY_FALLBACK_LLM=anthropic:claude-sonnet-4-20250514

# ---------------------------------------------------------------------------
# 可选：嵌入模型
# ---------------------------------------------------------------------------
# EMBEDDING=openai:text-embedding-3-small
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_API_KEY=
# OPENAI_EMBEDDING_BASE_URL=

# ---------------------------------------------------------------------------
# 数据库（Docker Compose 自动创建，无需修改）
# ---------------------------------------------------------------------------
POSTGRES_USER=rivalens
POSTGRES_PASSWORD=请修改为随机密码
POSTGRES_DB=rivalens
POSTGRES_PORT=5433

# ---------------------------------------------------------------------------
# Redis（Docker Compose 自动创建，无需修改）
# ---------------------------------------------------------------------------
REDIS_PASSWORD=请修改为随机密码
REDIS_PORT=6380

# ---------------------------------------------------------------------------
# 认证（生产环境务必修改 JWT Secret）
# ---------------------------------------------------------------------------
AUTH_JWT_SECRET=请修改为至少32位的随机字符串
AUTH_ACCESS_TOKEN_TTL_SECONDS=86400

# ---------------------------------------------------------------------------
# 可选：LangSmith 追踪
# ---------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=rivalens
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ---------------------------------------------------------------------------
# 报告生成
# ---------------------------------------------------------------------------
RIVALENS_MAX_ROOT_BRANCHES=20
RIVALENS_MAX_BRANCH_DEPTH=0
RIVALENS_MAX_EXPANSION_BRANCHES=0
RIVALENS_MAX_CONCURRENT_COLLECTIONS=3
RIVALENS_MAX_SUBQUERY_CONCURRENCY=2
# 每个进程共享的抓取线程与抓取请求硬上限
RIVALENS_SCRAPER_PROCESS_WORKERS=24

# 可选：LLM 分析模式（留空则用规则）
# RIVALENS_ANALYSIS_LLM=openai:gpt-4.1-mini
# RIVALENS_WRITER_LLM_CONCURRENCY=4
# 每个进程所有 Agent 共享的 LLM 在途请求硬上限
RIVALENS_LLM_PROCESS_CONCURRENCY=12

# LLM 全局限流（requests per minute，0 = 不限制）
RIVALENS_LLM_RPM_LIMIT=60

# ---------------------------------------------------------------------------
# Celery 后台任务
# ---------------------------------------------------------------------------
RIVALENS_CELERY_ENABLED=true
CELERY_WORKER_CONCURRENCY=2
# 报告幂等锁 TTL；留空时默认为任务硬超时加 300 秒
RIVALENS_CELERY_REPORT_LOCK_TTL_SECONDS=3900

# ---------------------------------------------------------------------------
# 其他开关
# ---------------------------------------------------------------------------
RIVALENS_TRACE_PERSISTENCE_ENABLED=true
RIVALENS_SESSION_PERSISTENCE_ENABLED=true
RIVALENS_ENABLE_EVIDENCE_RAG=true
RIVALENS_AUTO_CREATE_TABLES=true
RIVALENS_SCRAPED_SOURCE_CACHE_ENABLED=true
